# ============================================
# WxBot 环境变量配置文件
# ============================================

# LLM API 密钥（根据 config/default.json 中 llm.provider 选择对应密钥）
# 使用 OpenAI 时配置此项
OPENAI_API_KEY=sk-your-key-here

# 使用通义千问时配置此项
QWEN_API_KEY=your-qwen-key-here

# Web 控制面板端口（默认 3000）
WEB_PORT=13030

# 日志级别：0=DEBUG, 1=INFO, 2=WARN, 3=ERROR（默认 1）
LOG_LEVEL=1

# 视频下载器服务地址（默认使用 config/default.json 中的配置）
# DOWNLOADER_API_URL=https://www.yyyc1000.site
